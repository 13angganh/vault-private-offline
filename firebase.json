{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".firebase/**",
      "**/*.bat",
      "**/*.sh",
      "**/deploy*.bat",
      "**/deploy*.sh",
      "deploy.bat",
      "deploy.sh",
      "deploy-firebase.bat",
      "deploy-github.bat",
      "deploy-firebase.ps1",
      "deploy-github.ps1"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|svg|ico|webp)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000" }
        ]
      },
      {
        "source": "/manifest.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}